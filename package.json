{
  "name": "finish-em",
  "private": true,
  "type": "module",
  "bin": {
    "finish-em": "./src/cli.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "PATH=\"$HOME/.bun/bin:$PATH\" bun --watch src/tui/main.tsx",
    "tui": "PATH=\"$HOME/.bun/bin:$PATH\" bun src/tui/main.tsx",
    "build": "PATH=\"$HOME/.bun/bin:$PATH\" bun src/tui/build.ts bun-darwin-arm64 dist/finish-em",
    "build:x64": "PATH=\"$HOME/.bun/bin:$PATH\" bun src/tui/build.ts bun-darwin-x64 dist/finish-em-x64",
    "build:all": "PATH=\"$HOME/.bun/bin:$PATH\" bun run build && bun run build:x64",
    "app:build": "bash scripts/build-macos-app.sh",
    "app:install": "bash scripts/install-macos-app.sh",
    "cli:link": "bun link",
    "cli:install": "bash scripts/install-binary.sh",
    "cli:uninstall": "bash scripts/uninstall-binary.sh",
    "server:dev": "PATH=\"$HOME/.bun/bin:$PATH\" TODO_DB_PATH=\"${TODO_DB_PATH:-$HOME/.finish-em/todo.db}\" bun --watch src/server/http/main.ts",
    "web:dev": "vite --config src/web/vite.config.ts",
    "desktop:dev": "bun run server:dev & bun run web:dev",
    "web:build": "vite build --config src/web/vite.config.ts",
    "desktop:build": "bash scripts/build-desktop-binary.sh",
    "desktop:app": "bash scripts/build-desktop-app.sh",
    "openapi:write": "bun scripts/write-openapi.ts",
    "test": "bun test",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun scripts/db-migrate.mjs",
    "db:drizzle-migrate": "drizzle-kit migrate",
    "db:backup": "PATH=\"$HOME/.bun/bin:$PATH\" bun scripts/db-backup.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@inkjs/ui": "^2.0.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "ai": "^6.0.94",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "emojilib": "2",
    "hono": "^4.12.25",
    "ink": "^6.7.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^1.17.0",
    "react": "19.2.7",
    "react-devtools-core": "^7.0.1",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5",
    "bun-types": "^1.2.22",
    "drizzle-kit": "^0.31.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
