{
  "name": "finish-em",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx --watch src/tui/main.tsx",
    "build": "pnpm tui:build",
    "tui": "tsx src/tui/main.tsx",
    "tui:dev": "tsx --watch src/tui/main.tsx",
    "mcp": "tsx src/tui/main.tsx --headless-mcp",
    "tui:build": "bun src/tui/build.ts bun-darwin-arm64 dist/finish-em",
    "tui:build:x64": "bun src/tui/build.ts bun-darwin-x64 dist/finish-em-x64",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:drizzle-migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "ai": "^6.0.94",
    "better-sqlite3": "^11.9.1",
    "chrono-node": "^2.8.4",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "ink": "^6.7.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "rrule": "^2.8.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
