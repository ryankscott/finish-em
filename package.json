{
  "name": "finish-em",
  "private": true,
  "type": "module",
  "bin": {
    "finish-em": "./src/cli.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun --watch src/tui/main.tsx",
    "build": "bun run tui:build:all",
    "tui": "bun src/tui/main.tsx",
    "tui:dev": "bun --watch src/tui/main.tsx",
    "tui:build": "bun src/tui/build.ts bun-darwin-arm64 dist/finish-em",
    "tui:build:x64": "bun src/tui/build.ts bun-darwin-x64 dist/finish-em-x64",
    "tui:build:all": "bun run tui:build && bun run tui:build:x64",
    "app:build": "bash scripts/build-macos-app.sh",
    "app:install": "bash scripts/install-macos-app.sh",
    "cli:link": "bun link",
    "cli:build": "bun run tui:build",
    "cli:install": "bash scripts/install-binary.sh",
    "cli:uninstall": "bash scripts/uninstall-binary.sh",
    "test": "bun test",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun scripts/db-migrate.mjs",
    "db:drizzle-migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@inkjs/ui": "^2.0.0",
    "ai": "^6.0.94",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "emojilib": "2",
    "ink": "^6.7.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "bun-types": "^1.2.22",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
